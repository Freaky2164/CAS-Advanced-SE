{
  "name": "CAS Advanced SE",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}/Code",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "26",
      "installGradle": "true"
    },
  },
  "forwardPorts": [
    5432
  ],
  "postCreateCommand": "mkdir -p reports vorlagen excel import",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ]
    }
  }
}
